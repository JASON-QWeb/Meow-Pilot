{
  "name": "@pet/agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.cjs",
    "build": "rm -rf dist && esbuild src/server.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/server.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.80",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.66",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/xai": "^3.0.92",
    "@pet/protocol": "workspace:*",
    "ai": "^6.0.191",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
