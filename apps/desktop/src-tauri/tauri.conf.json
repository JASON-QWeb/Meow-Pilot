{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pet Agent",
  "version": "0.1.0",
  "identifier": "ai.petagent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm --filter @pet/protocol build && pnpm --filter @pet/agent-runtime build && pnpm --filter @pet/desktop build && pnpm --workspace-root tauri:prepare",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "pet",
        "title": "桌面宠物",
        "width": 180,
        "height": 180,
        "minWidth": 150,
        "minHeight": 150,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "resizable": false,
        "shadow": false,
        "acceptFirstMouse": true,
        "focus": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "work",
        "title": "宠物工作窗口",
        "width": 1580,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$DESKTOP/*", "$AUDIO/*", "$VIDEO/*", "$DOWNLOAD/*"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:4747 http://127.0.0.1:4747; img-src 'self' data: asset: http://asset.localhost; media-src 'self' blob: data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "resources": ["../../../packages/agent-runtime/dist", "resources/node", "resources/calendar-helper"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
